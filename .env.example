# Copie para .env e preencha com seus valores reais.
# Sem GEMINI_API_KEY e FIREBASE_CREDENTIALS, a aplicação sobe em modo DEMO
# (repositório em memória + IA fake), sem precisar de credenciais.

# Flask
SECRET_KEY=troque-por-uma-chave-segura

# Modo de operação (opcional): "demo" ou "real". Vazio = detecta automaticamente.
PRIMESTUDY_MODE=

# Google Gemini (necessário no modo real)
GEMINI_API_KEY=sua-chave-aqui
GEMINI_MODEL=gemini-2.5-flash

# Firebase / Firestore (necessário no modo real)
# Caminho para o JSON da service account do Firebase.
FIREBASE_CREDENTIALS=caminho/para/serviceAccount.json

# UID fixo usado no modo demo quando o login é dispensado (opcional).
DEMO_UID=demo-user
